rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ==================== HELPER FUNCTIONS ====================
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return request.auth.uid == uid;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // ==================== USER AVATARS ====================
    match /avatars/{uid}/{allPaths=**} {
      // Users can upload/delete their own avatar
      allow write: if isUser(uid) && isValidImage();

      // Anyone signed in can read avatars
      allow read: if isSignedIn();
    }

    // ==================== PROGRESS PROOFS ====================
    match /progress/{uid}/{allPaths=**} {
      // Users can upload proof for their progress
      allow write: if isUser(uid) && isValidImage();

      // Users can read their own proofs
      allow read: if isUser(uid);

      // Teachers and admins can read proofs for verification
      allow read: if hasRole('teacher') || hasRole('admin');
    }

    // ==================== ACTIVITY RESOURCES ====================
    match /activities/{activityId}/{allPaths=**} {
      // Only teachers and admins can manage activity resources, and only
      // valid, size-capped images.
      allow write: if (hasRole('teacher') || hasRole('admin')) && isValidImage();

      // All signed-in users can read activity resources
      allow read: if isSignedIn();
    }

    // ==================== DOCUMENT VAULT ====================
    // School reports, medical notes, etc. uploaded by a parent for a
    // linked child. linkedChildrenUids mirrors the same Firestore array
    // firestore.rules checks for document_vault Firestore doc access.
    match /document_vault/{childUid}/{fileName} {
      allow write: if hasRole('parent') &&
                      childUid in
                        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read: if isUser(childUid) ||
                      (hasRole('parent') &&
                       childUid in
                         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.linkedChildrenUids);
    }

    // ==================== DEFAULT DENY ====================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
