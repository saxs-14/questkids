rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ==================== HELPER FUNCTIONS ====================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(uid) {
      return request.auth.uid == uid;
    }
    
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
    
    // ==================== USER AVATARS ====================
    match /avatars/{uid}/{allPaths=**} {
      // Users can upload/delete their own avatar
      allow write: if isUser(uid) && isValidImage();
      
      // Anyone can read avatars
      allow read: if isSignedIn();
    }
    
    // ==================== PROGRESS PROOFS ====================
    match /progress/{uid}/{allPaths=**} {
      // Users can upload proof for their progress
      allow write: if isUser(uid) && isValidImage();
      
      // Users can read their own proofs
      allow read: if isUser(uid);
      
      // Teachers can read proofs for verification
      allow read: if isSignedIn();
    }
    
    // ==================== ACTIVITY RESOURCES ====================
    match /activities/{activityId}/{allPaths=**} {
      // Teachers and admins can manage activity resources
      allow write: if isSignedIn();
      
      // All signed-in users can read activity resources
      allow read: if isSignedIn();
    }
    
    // ==================== DEFAULT DENY ====================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
