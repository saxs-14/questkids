rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return request.auth.uid == uid;
    }

    // Roles are set exclusively by the admin/setUserRole Cloud Function as a
    // custom claim — never trust the mirrored `role` field on the user doc
    // for authorization decisions.
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && request.auth.token.role == 'teacher';
    }

    function isParent() {
      return isSignedIn() && request.auth.token.role == 'parent';
    }

    // Fields that can only ever be changed by a trusted server context
    // (Cloud Functions using the Admin SDK bypass rules entirely, so this
    // simply blocks clients from writing them directly).
    function lockedUserFields() {
      return ['role', 'xp', 'coins', 'level', 'linkedChildrenUids', 'uid', 'email'];
    }

    // ==================== USERS COLLECTION ====================
    match /users/{uid} {
      allow read: if isUser(uid);
      // POPIA: a learner account may only be created with a recorded
      // parent/guardian consent trail -- see CLAUDE.md §6.5 and
      // AppConstants.consentPolicyVersion. This is a server-side backstop;
      // the client (auth_service.dart) already always writes these fields
      // in the same set() call as account creation.
      allow create: if isUser(uid) &&
                       request.resource.data.uid == uid &&
                       request.resource.data.role == 'learner' &&
                       request.resource.data.consentGivenBy is string &&
                       request.resource.data.consentGivenBy.size() > 0 &&
                       request.resource.data.consentEmail is string &&
                       request.resource.data.consentEmail.size() > 0 &&
                       request.resource.data.consentAt is int &&
                       request.resource.data.policyVersion is string;
      allow update: if isUser(uid) &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(lockedUserFields());
      allow delete: if isUser(uid);

      // Parents can read their linked children
      allow read: if isParent() &&
                      uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;

      // Teachers can read learners they have actually added (the
      // linkedTeacherUids array is written by
      // teacher_dashboard.dart's _showAddLearnerDialog) -- not every
      // learner in the system.
      allow read: if isTeacher() &&
                      request.auth.uid in resource.data.linkedTeacherUids;

      // Chats subcollection — child and their linked parent only.
      // Teachers do NOT get access to AI chat logs.
      match /chats/{chatId} {
        allow read, write: if isUser(uid);
        allow read: if isParent() &&
                        uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      }
    }

    // ==================== ACTIVITIES COLLECTION ====================
    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if (isTeacher() || isAdmin());
      allow update: if (isTeacher() || isAdmin());
      allow delete: if isAdmin();
    }

    // ==================== PROGRESS COLLECTION ====================
    match /progress/{progressId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified']);

      // Parents can read and verify their children's progress
      allow read: if isParent() &&
                      resource.data.uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow update: if (isParent() || isTeacher()) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verified', 'proofUrl']);
    }

    // ==================== PARENT LINK REQUESTS ====================
    // Fields: primaryParentUid (the already-linked parent who must
    // approve), requestingParentUid (whoever is asking to be linked),
    // status ('pending'|'approved'|'declined').
    match /parent_link_requests/{requestId} {
      allow create: if isParent() &&
                        request.resource.data.requestingParentUid == request.auth.uid;
      allow read: if isParent() &&
                      (resource.data.primaryParentUid == request.auth.uid ||
                       resource.data.requestingParentUid == request.auth.uid);
      // Either the primary parent (approve/decline) or the requesting
      // parent (cancel their own still-pending request) may transition
      // status -- the requester may only act while it's still pending,
      // so they can't retroactively alter an already-resolved decision.
      allow update: if isParent() &&
                        ((resource.data.primaryParentUid == request.auth.uid) ||
                         (resource.data.requestingParentUid == request.auth.uid &&
                          resource.data.status == 'pending')) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
    }

    // ==================== SHARED CALENDAR ====================
    match /shared_calendar/{eventId} {
      allow create: if isParent() &&
                        request.resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read, update, delete: if isParent() &&
                        resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read: if isUser(resource.data.childUid);
    }

    // ==================== REMINDERS ====================
    match /reminders/{reminderId} {
      allow create: if isParent() &&
                        request.resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read, update, delete: if isParent() &&
                        resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
    }

    // ==================== DOCUMENT VAULT ====================
    match /document_vault/{docId} {
      allow create: if isParent() &&
                        request.resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read, update, delete: if isParent() &&
                        resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
    }

    // ==================== MOOD CHECK-INS ====================
    match /mood_checkins/{checkinId} {
      allow create: if isParent() &&
                        request.resource.data.childUid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      allow read: if isParent() &&
                      resource.data.childUid in
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      // Scoped to the entry's own logger, not any linked parent, so one
      // parent can't delete another linked parent's mood log entry.
      allow delete: if isParent() &&
                        resource.data.loggedByUid == request.auth.uid;
    }

    // ==================== EMAILS (write-only queue) ====================
    // Consumed by the sendEmail Cloud Function via the Admin SDK, which
    // bypasses these rules entirely -- clients only ever need to create.
    // Note: EmailService (the intended writer) currently has zero call
    // sites anywhere in lib/ -- this rule is preparatory, not unblocking
    // an active bug, so that the moment it's wired up it works correctly.
    match /emails/{emailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // ==================== REWARDS COLLECTION ====================
    match /rewards/{uid} {
      allow read, write: if isUser(uid);
      allow read: if isParent() &&
                      uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
    }

    // ==================== NOTIFICATIONS COLLECTION ====================
    // Supports both 'targetUid' (legacy) and 'recipientUid' (current) fields
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
                      resource.data.targetUid == request.auth.uid ||
                      resource.data.recipientUid == request.auth.uid);
      allow create: if isSignedIn() && (
                        request.resource.data.targetUid == request.auth.uid ||
                        request.resource.data.recipientUid == request.auth.uid);
      allow update: if isSignedIn() && (
                        resource.data.targetUid == request.auth.uid ||
                        resource.data.recipientUid == request.auth.uid) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'read']);
      allow delete: if isSignedIn() && (
                        resource.data.targetUid == request.auth.uid ||
                        resource.data.recipientUid == request.auth.uid) || isAdmin();
    }

    // ==================== GAME SESSIONS ====================
    match /game_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;

      // Parents and teachers can read their learners' sessions
      allow read: if isParent() &&
                      resource.data.uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      // Teachers can read sessions belonging to learners they've added --
      // look up the learner's own linkedTeacherUids (game_sessions docs
      // don't carry that array themselves, only the learner's uid).
      allow read: if isTeacher() &&
                      request.auth.uid in
                        get(/databases/$(database)/documents/users/$(resource.data.uid)).data.linkedTeacherUids;
    }

    // ==================== PLAYER STATS ====================
    match /player_stats/{uid} {
      allow read, write: if isUser(uid);
      allow read: if isParent() &&
                      uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
      // uid here is the learner's own uid (player_stats is keyed by it),
      // so look up that learner's linkedTeacherUids directly.
      allow read: if isTeacher() &&
                      request.auth.uid in
                        get(/databases/$(database)/documents/users/$(uid)).data.linkedTeacherUids;
    }

    // ==================== GAME PROGRESS (per-engine) ====================
    match /game_progress/{uid} {
      allow read, write: if isUser(uid);

      match /engines/{engineType} {
        allow read, write: if isUser(uid);
        allow read: if isParent() &&
                        uid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedChildrenUids;
        // uid here is the learner's own uid (game_progress is keyed by
        // it), so look up that learner's linkedTeacherUids directly.
        allow read: if isTeacher() &&
                        request.auth.uid in
                          get(/databases/$(database)/documents/users/$(uid)).data.linkedTeacherUids;
      }
    }

    // ==================== LEADERBOARDS ====================
    // Written daily by refreshLeaderboards Cloud Function; read-only for clients
    match /leaderboards/{grade} {
      allow read: if isSignedIn();
      allow write: if false;

      match /weekly/{entryId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /allTime/{entryId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ==================== DAILY MISSIONS ====================
    // Structure: daily_missions/{uid}/today/missions
    //            daily_missions/{uid}/assigned/{missionId}  (teacher writes)
    match /daily_missions/{uid} {
      allow read: if isUser(uid);
      allow write: if false;

      match /today/{doc} {
        allow read: if isUser(uid);
        allow update: if isUser(uid); // learner can mark completed
        allow create, delete: if false; // Cloud Functions only
      }

      match /assigned/{missionId} {
        allow read: if isUser(uid);
        allow write: if isTeacher();
      }
    }

    // ==================== CAPS CURRICULUM ====================
    // Read-only seeded reference data — all authenticated users can read
    match /caps_curriculum/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==================== AI REPORTS ====================
    // Child (or parent, via client) flags a Questy message; only admins can
    // review reports. Reporter cannot read back other users' reports.
    match /ai_reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ==================== AI USAGE QUOTA ====================
    // Written transactionally by the gemini proxy Cloud Functions only.
    match /usage_ai/{uid} {
      allow read: if isUser(uid);
      allow write: if false;
    }

    // Separate counter for getTeacherInsight so it never competes with a
    // learner's Questy chat quota above — written transactionally by that
    // Cloud Function only.
    match /usage_ai_teacher/{uid} {
      allow read: if isUser(uid);
      allow write: if false;
    }
  }
}
