# QuestKids Firebase Configuration
# Copy this file to .env and update with your actual values
# ⚠️ IMPORTANT: Never commit .env file to version control!

# Firebase Project
FIREBASE_PROJECT_ID=questkids-mobile
FIREBASE_PROJECT_NAME=QuestKids 2.0

# Email Configuration (for Cloud Functions)
# MAIL_SENDER is a plain var in functions/.env (see functions/.env.example).
# MAIL_PASSWORD is a real secret, not a .env value — set it once with:
#   firebase functions:secrets:set MAIL_PASSWORD
MAIL_SENDER=questkids.dev@gmail.com

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=tls

# Support Email
SUPPORT_EMAIL=support@questkids.com

# Google OAuth Credentials
# Get these from Google Cloud Console → Credentials
GOOGLE_CLIENT_ID_WEB=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=your-google-client-id.apps.googleusercontent.com

# Play Games (Android)
# Get this from Google Play Console
PLAY_GAMES_APP_ID=your-play-games-app-id

# Game Center (iOS)
# Use your bundle ID
GAME_CENTER_BUNDLE_ID=com.questkids.questkids

# Firebase Emulator Settings (for local development)
FIREBASE_EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080
AUTH_EMULATOR_PORT=9099
FUNCTIONS_EMULATOR_PORT=5001

# Environment
ENVIRONMENT=production  # development, staging, or production

# API Configuration
API_BASE_URL=https://api.questkids.com

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=true
ENABLE_GOOGLE_SIGNIN=true
ENABLE_PLAY_GAMES=true
ENABLE_GAME_CENTER=true
ENABLE_PARENT_CONSENT=true
ENABLE_FIREBASE_EMULATORS=false

# App Version
APP_VERSION=2.0.0
BUILD_NUMBER=1

# Gemini / Cloud Functions AI proxy — see functions/.env.example for the
# plain vars (GEMINI_MODEL, ENFORCE_APP_CHECK). GEMINI_API_KEY is a real
# secret, not a .env value anywhere — set it once with:
#   firebase functions:secrets:set GEMINI_API_KEY
