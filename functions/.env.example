# Cloud Functions runtime config — copy to functions/.env for local
# emulator use. Firebase Functions v2 auto-loads functions/.env (and
# functions/.env.<project-id> for project-specific overrides) at deploy
# time; these become plain process.env vars, NOT secrets.
#
# GEMINI_API_KEY and MAIL_PASSWORD are NOT here — they are real secrets
# (see functions/src/secrets.ts) and must never go in a .env file. Set
# them once per project with:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set MAIL_PASSWORD
# (paste the value when prompted; nothing is written to disk or git).

# gemini-2.5-flash is the current GA Flash model. Override only for a
# fast rollback if Google ships a breaking model change.
GEMINI_MODEL=gemini-2.5-flash

# Set to "true" only after App Check (Play Integrity + reCAPTCHA v3) is
# verified working end-to-end on every client platform that calls a
# Questy/teacher-insight function. See CLAUDE.md §6.2 and docs/SECURITY.md.
ENFORCE_APP_CHECK=false

# Public "From" address for transactional email — not secret.
MAIL_SENDER=questkids.dev@gmail.com
